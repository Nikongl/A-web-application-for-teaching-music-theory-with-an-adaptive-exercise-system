{
  "info": {
    "name": "Music App API Tests (full)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Exercise Types",
      "item": [
        {
          "name": "GET all exercise types",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Response is array', function() { pm.expect(pm.response.json()).to.be.an('array'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "http://localhost:8000/api/exercise-types/"
          }
        },
        {
          "name": "POST create exercise type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function() { pm.response.to.have.status(201); });",
                  "pm.test('Response has name and id', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('name');",
                  "  pm.expect(json).to.have.property('id');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "http://localhost:8000/api/exercise-types/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Тестовый тип\",\n  \"code\": \"test_type\",\n  \"icon\": \"🎵\",\n  \"order\": 99\n}"
            }
          }
        },
        {
          "name": "GET specific exercise type by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Response has id and name', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('name');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "http://localhost:8000/api/exercise-types/1/"
          }
        },
        {
          "name": "PUT update exercise type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Name updated', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.name).to.eql('Обновлённый тип');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "http://localhost:8000/api/exercise-types/1/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Обновлённый тип\",\n  \"code\": \"test_type\",\n  \"icon\": \"🎹\",\n  \"order\": 100\n}"
            }
          }
        },
        {
          "name": "DELETE exercise type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', function() { pm.response.to.have.status(204); });"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "http://localhost:8000/api/exercise-types/1/"
          }
        },
        {
          "name": "GET exercise type - 404 not found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function() { pm.response.to.have.status(404); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "http://localhost:8000/api/exercise-types/99999/"
          }
        },
        {
          "name": "POST create exercise type - bad request (missing name)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function() { pm.response.to.have.status(400); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "http://localhost:8000/api/exercise-types/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"bad\",\n  \"icon\": \"🎵\"\n}"
            }
          }
        }
      ]
    },
